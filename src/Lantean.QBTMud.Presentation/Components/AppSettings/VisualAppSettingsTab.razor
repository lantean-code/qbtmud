@namespace Lantean.QBTMud.Components.AppSettingsTabs
<MudCard Elevation="1" Class="ml-4 mr-4 mb-4 mt-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.subtitle2">@TranslateSettings("Visual")</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="pt-0">
        <MudGrid>
            <MudItem xs="12">
                <MudSelect T="ThemeModePreference"
                           Value="@Settings.ThemeModePreference"
                           ValueChanged="OnThemeModePreferenceChanged"
                           Label="@TranslateSettings("Theme mode")"
                           Variant="Variant.Outlined"
                           ShrinkLabel="true"
                           HelperText="@TranslateSettings("Choose whether qbtmud follows the system appearance or uses a fixed mode.")"
                           data-test-id="@TestIdHelper.For("AppSettingsThemeModePreference")">
                    <MudSelectItem Value="@ThemeModePreference.System">@TranslateSettings("Follow system")</MudSelectItem>
                    <MudSelectItem Value="@ThemeModePreference.Light">@TranslateSettings("Light")</MudSelectItem>
                    <MudSelectItem Value="@ThemeModePreference.Dark">@TranslateSettings("Dark")</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField T="string"
                              Value="@Settings.ThemeRepositoryIndexUrl"
                              ValueChanged="OnThemeRepositoryIndexUrlChanged"
                              Immediate="true"
                              Label="@TranslateSettings("Theme repository index URL")"
                              Variant="Variant.Outlined"
                              ShrinkLabel="true"
                              HelperText="@TranslateSettings("Optional HTTPS URL to a theme index.json file. Leave blank to disable repository themes.")"
                              Error="@(!IsThemeRepositoryIndexUrlValid)"
                              ErrorText="@ThemeRepositoryIndexUrlErrorText"
                              data-test-id="@TestIdHelper.For("AppSettingsThemeRepositoryIndexUrl")" />
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

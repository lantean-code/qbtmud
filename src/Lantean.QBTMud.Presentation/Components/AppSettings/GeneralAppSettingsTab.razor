@namespace Lantean.QBTMud.Components.AppSettingsTabs
<MudCard Elevation="1" Class="ml-4 mr-4 mb-4 mt-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.subtitle2">@TranslateSettings("General")</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="pt-0">
        <MudGrid>
            <MudItem xs="12">
                <FieldSwitch Value="@Settings.SpeedHistoryEnabled"
                             ValueChanged="OnSpeedHistoryEnabledChanged"
                             Label="@TranslateSettings("Speed history")"
                             HelperText="@TranslateSettings("Keep a local history of transfer speeds for the Speed page.")"
                             data-test-id="@TestIdHelper.For("AppSettingsSpeedHistoryEnabled")" />
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

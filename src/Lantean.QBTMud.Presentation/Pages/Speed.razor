@page "/speed"
@layout OtherLayout
<div class="speed-page">
<ContentPanel UseContainer="true" ContainerClass="pt-4">
    <ToolbarContent>
        <MudToolBar Gutters="false" Dense="true">
            @if (!DrawerOpen)
            {
                <MudIconButton Icon="@Icons.Material.Outlined.NavigateBefore" OnClick="NavigateBack" title="@Translate("Back to torrent list")" />
                <MudDivider Vertical="true" />
            }
            <MudDivider Vertical="true" />
            <MudText Class="pl-5 no-wrap">@Translate("Speed")</MudText>
        </MudToolBar>
    </ToolbarContent>
    <ChildContent>
            <MudPaper Class="pa-4 mb-4">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                    <MudToggleGroup T="SpeedPeriod"
                                    Color="Color.Primary"
                                    Outlined="true"
                                    Delimiters="true"
                                    SelectionMode="SelectionMode.SingleSelection"
                                    Size="Size.Small"
                                    Value="_selectedPeriod"
                                    ValueChanged="OnPeriodChanged"
                                    data-test-id="@TestIdHelper.For("PeriodToggleGroup")">
                        @foreach (var option in _periodOptions)
                        {
                            <MudToggleItem Value="option.Period" data-test-id="@TestIdHelper.For($"PeriodToggle-{option.Period}")">@Translate(option.Label)</MudToggleItem>
                        }
                    </MudToggleGroup>
                    <MudSpacer />
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudSwitch T="bool" Value="@_includeDownload" ValueChanged="ToggleDownload" Color="Color.Success" Label="@Translate("Download")" data-test-id="@TestIdHelper.For("DownloadToggle")" />
                        <MudSwitch T="bool" Value="@_includeUpload" ValueChanged="ToggleUpload" Color="Color.Info" Label="@Translate("Upload")" data-test-id="@TestIdHelper.For("UploadToggle")" />
                    </MudStack>
                </MudStack>
            </MudPaper>

            @if (_series.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    @Translate("No speed data yet. Keep this tab open to accumulate history.")
                </MudAlert>
            }
            else
            {
                <MudPaper Class="pa-4 speed-chart-container" data-test-id="@TestIdHelper.For("SpeedChartContainer")">
                    <div class="speed-chart-frame">
                        <MudChart T="double"
                                  ChartType="ChartType.Timeseries"
                                  ChartSeries="@_series"
                                  ChartOptions="@_chartOptions"
                                  MatchBoundsToSize="true"
                                  Height="320px"
                                  Width="100%"
                                  Class="speed-chart"
                                  data-test-id="@TestIdHelper.For("SpeedChart")" />
                    </div>
                    <MudText Typo="Typo.caption" Class="speed-chart-updated" data-test-id="@TestIdHelper.For("SpeedChartLastUpdated")">
                        @Translate("Last updated:") @_lastUpdatedText
                    </MudText>
                </MudPaper>
            }
    </ChildContent>
</ContentPanel>
</div>

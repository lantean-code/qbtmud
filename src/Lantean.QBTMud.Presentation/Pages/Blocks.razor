@using QBittorrent.ApiClient.Models
@page "/blocks"
@layout OtherLayout
<MudMenu @ref="ContextMenu" Dense="true" PositionAtCursor="true" ListClass="unselectable" PopoverClass="unselectable">
    <MudMenuItem Icon="@Icons.Material.Filled.ContentCopy" IconColor="Color.Info" Disabled="@(ContextMenuItem is null)" OnClick="CopyContextMenuItem">@LanguageLocalizer.Translate("ExecutionLogWidget", "Copy")</MudMenuItem>
    <MudDivider />
    <MudMenuItem Icon="@Icons.Material.Filled.Clear" IconColor="Color.Error" Disabled="@(!HasResults)" OnClick="ClearResults">@LanguageLocalizer.Translate("ExecutionLogWidget", "Clear")</MudMenuItem>
</MudMenu>

<ContentPanel>
    <ToolbarContent>
        <MudToolBar Gutters="false" Dense="true">
            @if (!DrawerOpen)
            {
                <MudIconButton Icon="@Icons.Material.Outlined.NavigateBefore" OnClick="NavigateBack" title="Back to torrent list" />
                <MudDivider Vertical="true" />
            }
            <MudDivider Vertical="true" />
            <ToolbarTitle Class="pl-5">@LanguageLocalizer.Translate("ExecutionLogWidget", "Blocked IPs")</ToolbarTitle>
        </MudToolBar>
    </ToolbarContent>
    <ChildContent>
        <MudCard Elevation="1" Class="ml-4 mr-4 mb-4">
            <MudCardContent>
                <EditForm Model="Model" OnSubmit="Submit">
                    <MudGrid>
                        <MudItem md="10">
                            <MudTextField T="string" Label="@LanguageLocalizer.Translate("ExecutionLogWidget", "Filter logs")" @bind-Value="Model.Criteria" Variant="Variant.Outlined" ShrinkLabel="true" />
                        </MudItem>
                        <MudItem md="2">
                            <MudButton ButtonType="ButtonType.Submit" FullWidth="true" Color="Color.Primary" EndIcon="@Icons.Material.Filled.Search" Variant="Variant.Filled" Class="mt-6">@LanguageLocalizer.Translate("SearchEngineWidget", "Filter")</MudButton>
                        </MudItem>
                    </MudGrid>
                </EditForm>
            </MudCardContent>
        </MudCard>

        <DynamicTable @ref="Table"
                      TableId="Blocks"
                      T="PeerLog"
                      ColumnDefinitions="Columns"
                      Items="Results"
                      MultiSelection="false"
                      SelectOnRowClick="false"
                      RowClassFunc="RowClass"
                      OnTableDataContextMenu="TableDataContextMenu"
                      OnTableDataLongPress="TableDataLongPress"
                      Class="search-list content-panel__table" />
    </ChildContent>
</ContentPanel>

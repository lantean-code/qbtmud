@page "/app-settings"
@layout OtherLayout
@using Lantean.QBTMud.Components.AppSettingsTabs

<NavigationLock ConfirmExternalNavigation="@HasPendingChanges" OnBeforeInternalNavigation="ValidateExit" />

<ContentPanel>
    <ToolbarContent>
        <MudToolBar Gutters="false" Dense="true">
            @if (!DrawerOpen)
            {
                <MudIconButton Icon="@Icons.Material.Outlined.NavigateBefore"
                               OnClick="NavigateBack"
                               title="@TranslateSettings("Back to torrent list")"
                               data-test-id="@TestIdHelper.For("AppSettingsBackButton")" />
                <MudDivider Vertical="true" />
            }
            <MudText Class="px-5 no-wrap">@TranslateSettings("App Settings")</MudText>
            <MudDivider Vertical="true" />
            <MudIconButton Icon="@Icons.Material.Outlined.Save"
                           OnClick="Save"
                           Disabled="@(!HasPendingChanges)"
                           data-test-id="@TestIdHelper.For("AppSettingsSaveButton")" />
            <MudIconButton Icon="@Icons.Material.Outlined.Undo"
                           OnClick="Undo"
                           Disabled="@(!HasPendingChanges)"
                           data-test-id="@TestIdHelper.For("AppSettingsUndoButton")" />
            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                           OnClick="Reload"
                           title="@TranslateSettings("Refresh")"
                           Disabled="@(IsLoading || IsReloading || IsStorageBusy)"
                           data-test-id="@TestIdHelper.For("AppSettingsReloadButton")" />
        </MudToolBar>
    </ToolbarContent>

    <ChildContent>
        @if (IsLoading)
        {
            <MudProgressLinear Color="Color.Primary"
                               Indeterminate="true"
                               Class="my-4"
                               data-test-id="@TestIdHelper.For("AppSettingsLoading")" />
        }
        else
        {
            <MudTabs Elevation="2"
                     ApplyEffectsToContainer="true"
                     ActivePanelIndex="@ActiveTab"
                     ActivePanelIndexChanged="OnActiveTabChanged"
                     Border="true"
                     KeepPanelsAlive="true">
                <MudTabPanel Text="@TranslateSettings("Visual")"
                             data-test-id="@TestIdHelper.For("AppSettingsVisualTab")">
                    <div class="options-tab-contents">
                        <VisualAppSettingsTab Settings="@Settings"
                                              SettingsChanged="OnSettingsChanged" />
                    </div>
                </MudTabPanel>

                <MudTabPanel Text="@TranslateUpdates("Updates")">
                    <div class="options-tab-contents">
                        <UpdatesAppSettingsTab Settings="@Settings"
                                               SettingsChanged="OnSettingsChanged"
                                               ReloadToken="@ReloadToken" />
                    </div>
                </MudTabPanel>

                <MudTabPanel Text="@TranslateNotifications("Notifications")">
                    <div class="options-tab-contents">
                        <NotificationsAppSettingsTab Settings="@Settings"
                                                     SettingsChanged="OnSettingsChanged"
                                                     NotificationsEnabledCorrected="OnNotificationsEnabledCorrected"
                                                     ReloadToken="@ReloadToken" />
                    </div>
                </MudTabPanel>

                <MudTabPanel Text="@TranslateSettings("Storage")">
                    <div class="options-tab-contents">
                        <StorageAppSettingsTab StorageRoutingSettings="@StorageRoutingSettings"
                                               IsActive="@IsStorageTabActive"
                                               ReloadToken="@ReloadToken"
                                               StorageRoutingChanged="OnStorageRoutingChanged"
                                               BusyChanged="OnStorageBusyChanged" />
                    </div>
                </MudTabPanel>

                <MudTabPanel Text="@TranslatePwa("PWA")"
                             data-test-id="@TestIdHelper.For("AppSettingsPwaTab")">
                    <div class="options-tab-contents">
                        <PwaAppSettingsTab IsActive="@IsPwaTabActive"
                                           ReloadToken="@ReloadToken" />
                    </div>
                </MudTabPanel>
            </MudTabs>
        }
    </ChildContent>
</ContentPanel>

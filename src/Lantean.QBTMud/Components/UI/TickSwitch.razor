@inherits MudSwitch<T>
@typeparam T
@{
    base.BuildRenderTree(__builder);
}

@code{
    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        UpdateThumbIcon(BoolValue);
    }

    protected override async Task OnChange(ChangeEventArgs args)
    {
        await base.OnChange(args);
        UpdateThumbIcon(BoolValue);
    }

    private void UpdateThumbIcon(bool? boolValue)
    {
        if (boolValue is null)
        {
            ThumbIcon = null;
            ThumbIconColor = Color.Default;
            return;
        }

        ThumbIcon = boolValue.Value ? Icons.Material.Filled.Done : Icons.Material.Filled.Close;
        ThumbIconColor = boolValue.Value ? Color.Success : Color.Error;
    }
}

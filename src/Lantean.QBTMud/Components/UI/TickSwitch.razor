@inherits MudSwitch<T>
@typeparam T
@{
    base.BuildRenderTree(__builder);
}

@code{
    protected override void OnParametersSet()
    {
        var boolValue = BoolValue;
        if (boolValue is null)
        {
            return;
        }

        ThumbIcon = boolValue.Value ? Icons.Material.Filled.Done : Icons.Material.Filled.Close;
        ThumbIconColor = boolValue.Value ? Color.Success : Color.Error;
    }
}

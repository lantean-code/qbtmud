@using Microsoft.AspNetCore.Components.Web

<MudStack Spacing="1" Class="pwa-install-snackbar-content">
    <MudText Typo="Typo.body1" Class="pwa-install-snackbar-message">@Message</MudText>
    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="pwa-install-snackbar-actions">
        @if (ShowInstallButton)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       Class="pwa-install-snackbar-button"
                       OnClick="OnInstallClicked">
                @InstallLabel
            </MudButton>
        }
        <MudButton Variant="Variant.Filled"
                   Color="Color.Warning"
                   Class="pwa-install-snackbar-button"
                   OnClick="OnDismissClicked">
            @DismissLabel
        </MudButton>
    </MudStack>
</MudStack>

@code
{
    [Parameter]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public string InstallLabel { get; set; } = string.Empty;

    [Parameter]
    public string DismissLabel { get; set; } = string.Empty;

    [Parameter]
    public bool ShowInstallButton { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnInstallClicked { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnDismissClicked { get; set; }
}

@using QBittorrent.ApiClient.Models
@using MudBlazor
@using System.Globalization
@using Lantean.QBTMud.Helpers

<MudPaper Class="@RootClass" Elevation="0">
    <MudStack Spacing="0">
        <Tooltip Text="@LinearTooltip" Placement="Placement.Top">
            <div class="@LinearClass" role="button" tabindex="0" aria-expanded="@_showSvg.ToString().ToLowerInvariant()" aria-label="@LinearAriaLabel" data-test-id="@TestIdHelper.For("PiecesToggle")" @onclick="ToggleSvg" @onkeydown="HandleLinearKeyDown" @onkeydown:preventDefault="true">
                <div class="pieces-progress-svg__linear-bar" style="@LinearBarStyle" aria-hidden="true"></div>
                <div class="pieces-progress-svg__linear-overlay" style="@LinearOverlayStyle" data-test-id="@TestIdHelper.For("PiecesLinearOverlay")">
                    <MudText Typo="Typo.body2"
                             Class="pl-2"
                             data-test-id="@TestIdHelper.For("PiecesLinearSummary")"
                             >@LinearSummary</MudText>
                    <MudIcon Icon="@ToggleIcon" Class="pieces-progress-svg__icon" />
                </div>
            </div>
        </Tooltip>

        <MudCollapse Expanded="@_showSvg">
            <MudPaper Class="@SurfaceClass" Elevation="0">
                @if (PiecesLoading)
                {
                    <MudText Typo="Typo.body2"
                             Class="pieces-progress-svg__empty"
                             data-test-id="@TestIdHelper.For("PiecesLoadingText")">@SvgLoadingText</MudText>
                }
                else if (_svgBuilding)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pieces-progress-svg__empty" data-test-id="@TestIdHelper.For("PiecesSpinner")">
                        <MudProgressCircular Color="Color.Info" Indeterminate="true" Size="Size.Large" />
                        <MudText Typo="Typo.body2" Class="ml-4">@TranslateApp("Rendering pieces...")</MudText>
                    </MudStack>
                }
                else if (PiecesFailed || !HasPieceData)
                {
                    <MudText Typo="Typo.body2"
                             Class="pieces-progress-svg__empty"
                             data-test-id="@TestIdHelper.For("PiecesEmptyText")">@SvgEmptyText</MudText>
                }
                else if (ColumnsForCurrentBreakpoint == 0)
                {
                    <MudText Typo="Typo.body2"
                             Class="pieces-progress-svg__empty"
                             data-test-id="@TestIdHelper.For("PiecesHiddenText")">@SvgHiddenText</MudText>
                }
                else
                {
                    <svg class="pieces-progress-svg__grid"
                         style="@GridStyle"
                         role="img"
                         aria-label="@SvgAriaLabel"
                         viewBox="@_viewBox"
                         preserveAspectRatio="xMidYMid meet">
                        <defs>
                            <style>
                                .pieces-progress-svg__rect { stroke-width: 0.03; stroke-linejoin: round; }
                                .pieces-progress-svg__rect--downloaded { fill: @DownloadedColor; stroke: @DownloadedColor; }
                                .pieces-progress-svg__rect--downloading { fill: @DownloadingColor; stroke: @DownloadingColor; }
                                .pieces-progress-svg__rect--pending { fill: transparent; stroke: @PendingStrokeColor; }
                            </style>
                        </defs>
                        @foreach (var cell in Cells)
                        {
                            <rect class="pieces-progress-svg__rect @cell.CssClass"
                                  x="@cell.X.ToString("0.###", CultureInfo.InvariantCulture)"
                                  y="@cell.Y.ToString("0.###", CultureInfo.InvariantCulture)"
                                  width="@cell.Width.ToString("0.###", CultureInfo.InvariantCulture)"
                                  height="@cell.Height.ToString("0.###", CultureInfo.InvariantCulture)">
                                <title>@cell.Tooltip</title>
                            </rect>
                        }
                    </svg>
                }
            </MudPaper>
        </MudCollapse>
    </MudStack>
</MudPaper>
